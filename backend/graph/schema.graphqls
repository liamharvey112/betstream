type Bet {
    id: String!
    userId: String!
    eventId: String!
    amount: Float!
    odds: Float!
    status: String!    
    createdAt: String!
}

type Query {
    bets(userId: String!): [Bet!]!
    bet(id: String!): Bet
}

type Mutation {
    placeBet(userId: String!, eventId: String!, amount: Float!, odds: Float!): Bet!
}